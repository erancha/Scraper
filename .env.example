# SMTP credentials for sending email notifications.
# For Gmail: use an App Password (not your regular password).
#
# How to create a Gmail App Password:
#   1. Ensure 2-Step Verification is enabled at https://myaccount.google.com/security
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Type an app name (e.g. "NBA Scraper") and click "Create"
#   4. Copy the 16-character password shown and paste it as SMTP_PASS below
#   5. Set SMTP_USER to the same Gmail address you generated the password for
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Recipient email(s), comma-separated for multiple
#
# You can also override per provider. Resolution order:
# - EMAIL_TO__<PROVIDER_KEY>
# - EMAIL_TO
#
# Provider keys are taken from providers/__init__.py and normalized to upper snake case.
# Examples:
# - espn-nba   -> EMAIL_TO__ESPN_NBA
# - ynet-sport -> EMAIL_TO__YNET_SPORT
# - ynet-news  -> EMAIL_TO__YNET_NEWS
EMAIL_TO=recipient-email@gmail.com
#EMAIL_TO__ESPN_NBA=nba-recipient@gmail.com
#EMAIL_TO__YNET_SPORT=sport-recipient@gmail.com
#EMAIL_TO__YNET_NEWS=news-recipient@gmail.com

# Polling interval in seconds (default: 300 = 5 minutes)
CHECK_INTERVAL=300

LOG_LEVEL=INFO # Logging verbosity: DEBUG < INFO < WARNING < ERROR < CRITICAL (e.g. INFO shows WARNING/ERROR/CRITICAL too)

# Docker Hub (optional)
# Used by docker/build-and-push.sh and docker/deploy.sh when you pass --dockerhub.
# Pulling a public image does not require authentication. Pushing requires auth.
# Create a personal access token at:
#   https://app.docker.com/accounts/<username>/settings/personal-access-tokens
# Token permission must allow pushing (e.g. "Read & Write").
DOCKERHUB_NAMESPACE=
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=
